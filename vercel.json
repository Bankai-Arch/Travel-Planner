{
  "version": 2,

  "buildCommand": "cd server && npm install && npm run build && cd ../client && npm install && npm run build",
  "outputDirectory": "client/.next",
  "installCommand": "echo 'install handled per-directory in buildCommand'",

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/$1"
    }
  ],

  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/dist/**"
    }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin",      "value": "*" },
        { "key": "Access-Control-Allow-Methods",     "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers",     "value": "Authorization, Content-Type, X-Requested-With, Accept" }
      ]
    }
  ],

  "env": {
    "NODE_ENV": "production"
  }
}
